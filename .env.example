# ============================================
# Bitebi Environment Variables
# ============================================

# ── AI Content Generation (Required) ──────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# Gemini model to use (optional, default: gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Site Configuration ─────────────────────────
# Your production site URL (required for SEO, OG images)
NEXT_PUBLIC_SITE_URL=https://bitebi.vercel.app

# Manual ad slots rendering (false = auto ads only, recommended)
NEXT_PUBLIC_MANUAL_ADS=false

# ── Optional API Keys ──────────────────────────
# Alchemy API for whale tracking (get from: https://alchemy.com)
ALCHEMY_API_KEY=your_alchemy_api_key_here

# FRED API for money supply data (get from: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# ============================================
# GitHub Secrets Setup (for GitHub Actions)
# ============================================
# Add these secrets to your GitHub repository:
# Settings → Secrets and variables → Actions → New repository secret
#
# Required secrets:
# - GEMINI_API_KEY
#
# Optional secrets:
# - NEXT_PUBLIC_SITE_URL
# - ALCHEMY_API_KEY
# - FRED_API_KEY
